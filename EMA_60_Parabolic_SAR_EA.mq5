//+------------------------------------------------------------------+\n//| Expert Advisor: EMA 60 + Parabolic SAR Trading System            |\n//+------------------------------------------------------------------+\n#property strict\n\n// Input Parameters\ninput double LotSize = 0.01;\ninput int StopLoss = 50;\ninput int TakeProfit = 100;\ninput int MaxOpenTrades = 1;\n\n// EMA Parameters\ninput int EMAPeriod = 60;\ninput int EMAShift = 0;\ninput ENUM_MA_METHOD EMAMethod = MODE_EMA;\ninput ENUM_APPLIED_PRICE EMAAppliedPrice = PRICE_CLOSE;\n\n// Parabolic SAR Parameters\ninput double PSARStep = 0.020;\ninput double PSARMaximum = 0.200;\n\n// Magic Number for order identification\ninput int MagicNumber = 1001;\n\n// Global variables\nint totalOrders = 0;\n\n//+------------------------------------------------------------------+\n//| Expert initialization function                                   |\n//+------------------------------------------------------------------+\nint OnInit()\n{\n    return(INIT_SUCCEEDED);\n}\n\n//+------------------------------------------------------------------+\n//| Expert deinitialization function                                 |\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason)\n{\n    // Cleanup if needed\n}\n\n//+------------------------------------------------------------------+\n//| Expert tick function                                             |\n//+------------------------------------------------------------------+\nvoid OnTick()\n{\n    // Check all timeframes\n    CheckSignalsAllTimeframes();\n}\n\n//+------------------------------------------------------------------+\n//| Check signals for all timeframes                                 |\n//+------------------------------------------------------------------+\nvoid CheckSignalsAllTimeframes()\n{\n    // Array of timeframes to check\n    ENUM_TIMEFRAMES timeframes[] = {\n        PERIOD_M1, PERIOD_M5, PERIOD_M15, PERIOD_M30,\n        PERIOD_H1, PERIOD_H4, PERIOD_D1, PERIOD_W1, PERIOD_MN1\n    };\n    \n    // Check each timeframe\n    for(int i = 0; i < ArraySize(timeframes); i++)\n    {\n        string signal = GetSignal(_Symbol, timeframes[i]);\n        \n        if(signal == "BUY" && CountOpenTrades() < MaxOpenTrades)\n        {\n            SendOrder(ORDER_TYPE_BUY);\n        }\n        else if(signal == "SELL" && CountOpenTrades() < MaxOpenTrades)\n        {\n            SendOrder(ORDER_TYPE_SELL);\n        }\n    }\n}\n\n//+------------------------------------------------------------------+\n//| Get trading signal                                               |\n//+------------------------------------------------------------------+\nstring GetSignal(string symbol, ENUM_TIMEFRAMES timeframe)\n{\n    // Get EMA value\n    double ema = iMA(symbol, timeframe, EMAPeriod, EMAShift, EMAMethod, EMAAppliedPrice, 0);\n    \n    // Get current close price\n    double close = iClose(symbol, timeframe, 0);\n    \n    // Get Parabolic SAR value\n    double psar = iSAR(symbol, timeframe, PSARStep, PSARMaximum, 0);\n    \n    // BUY CONDITION: Price > EMA and SAR < Price\n    if(close > ema && psar < close)\n    {\n        return "BUY";\n    }\n    \n    // SELL CONDITION: Price < EMA and SAR > Price\n    if(close < ema && psar > close)\n    {\n        return "SELL";\n    }\n    \n    return "NEUTRAL";\n}\n\n//+------------------------------------------------------------------+\n//| Send order to market                                             |\n//+------------------------------------------------------------------+\nvoid SendOrder(ENUM_ORDER_TYPE orderType)\n{\n    MqlTradeRequest request = {};\n    MqlTradeResult result = {};\n    \n    // Get current tick\n    MqlTick tick;\n    SymbolInfoTick(_Symbol, tick);\n    \n    // Set request parameters\n    request.action = TRADE_ACTION_DEAL;\n    request.symbol = _Symbol;\n    request.volume = LotSize;\n    request.type = orderType;\n    request.price = (orderType == ORDER_TYPE_BUY) ? tick.ask : tick.bid;\n    request.deviation = 20;\n    request.magic = MagicNumber;\n    request.comment = (orderType == ORDER_TYPE_BUY) ? "Buy Signal" : "Sell Signal";\n    request.type_time = ORDER_TIME_GTC;\n    request.type_filling = ORDER_FILLING_IOC;\n    \n    // Set stop loss and take profit\n    if(orderType == ORDER_TYPE_BUY)\n    {\n        request.sl = request.price - (StopLoss * _Point);\n        request.tp = request.price + (TakeProfit * _Point);\n    }\n    else\n    {\n        request.sl = request.price + (StopLoss * _Point);\n        request.tp = request.price - (TakeProfit * _Point);\n    }\n    \n    // Send order\n    if(!OrderSend(request, result))\n    {\n        Print("Order failed. Error: ", GetLastError());\n    }\n    else\n    {\n        Print("Order sent successfully. Ticket: ", result.order);\n    }\n}\n\n//+------------------------------------------------------------------+\n//| Count open trades with magic number                              |\n//+------------------------------------------------------------------+\nint CountOpenTrades()\n{\n    int count = 0;\n    \n    for(int i = PositionsTotal() - 1; i >= 0; i--)\n    {\n        if(PositionSelectByTicket(PositionGetTicket(i)))\n        {\n            if(PositionGetInteger(POSITION_MAGIC) == MagicNumber &&  \n               PositionGetString(POSITION_SYMBOL) == _Symbol)\n            {\n                count++;\n            }\n        }\n    }\n    \n    return count;\n}\n\n//+------------------------------------------------------------------+\n//| End of Expert Advisor                                            |\n//+------------------------------------------------------------------+